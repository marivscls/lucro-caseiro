{
  "expo": {
    "name": "Lucro Caseiro: Negocio em Casa",
    "slug": "lucro-caseiro-dev",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "lucrocaseiro",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E1814"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lucrocaseiro.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1E1814"
      },
      "package": "br.com.orionseven.lucrocaseiro",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#22C55E",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar suas fotos para adicionar imagens a produtos e receitas.",
          "cameraPermission": "O app precisa acessar a camera para tirar fotos de produtos e receitas."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8304398247631710~5581735015",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f1dbfa95-c134-44cd-855c-52fc8bb1c3f3"
      },
      "admob": {
        "bannerUnitIdAndroid": "ca-app-pub-8304398247631710/6992108312",
        "interstitialUnitIdAndroid": "ca-app-pub-8304398247631710/5985224969"
      }
    },
    "owner": "marivscls5"
  }
}
