{
  "name": "lucro-caseiro",
  "version": "0.0.1",
  "private": true,
  "description": "Gestao completa para negocios caseiros",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "@xmldom/xmldom@<0.8.13": "0.8.13",
      "fast-uri@<=3.1.1": "3.1.2",
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.0",
      "shell-quote@>=1.1.0 <=1.8.3": "1.8.4",
      "tmp@<0.2.7": "0.2.7",
      "undici@<6.27.0": "6.27.0",
      "ws@>=6.0.0 <6.2.4": "6.2.4",
      "ws@>=7.0.0 <7.5.11": "7.5.11",
      "ws@>=8.0.0 <8.21.0": "8.21.0"
    }
  },
  "scripts": {
    "dev": "turbo run dev",
    "start": "pnpm --filter @lucro-caseiro/api start",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "sherif": "sherif",
    "knip": "knip",
    "knip:full": "knip --include-entry-exports",
    "check": "pnpm lint && pnpm typecheck && pnpm build",
    "prepush": "pnpm lint && pnpm typecheck && pnpm test && pnpm sherif && pnpm context:lint",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm sherif && pnpm knip:full && pnpm context:lint && pnpm build",
    "context:lint": "node scripts/context-lint-api.mjs && node scripts/context-lint-mobile.mjs",
    "context:lint:api": "node scripts/context-lint-api.mjs",
    "context:lint:mobile": "node scripts/context-lint-mobile.mjs",
    "context:lint:changed": "node scripts/context-lint-api.mjs --changed && node scripts/context-lint-mobile.mjs --changed",
    "context:lint:staged": "node scripts/context-lint-api.mjs --staged && node scripts/context-lint-mobile.mjs --staged",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.2",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "knip": "^5.0.0",
    "lint-staged": "^16.0.0",
    "prettier": "^3.4.2",
    "sherif": "^1.0.0",
    "turbo": "^2.8.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
