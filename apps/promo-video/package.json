    "render:campaigns": "remotion render LucroCaseiroFinanceiro out/lucro-caseiro-financeiro.mp4 && remotion render LucroCaseiroCatalogo out/lucro-caseiro-catalogo.mp4 && remotion render LucroCaseiroProfissional out/lucro-caseiro-profissional.mp4",
    "render:tour": "remotion render LucroCaseiroTourReal out/lucro-caseiro-tour-real.mp4"
  },
  "sideEffects": [
    "*.css"
  ]
