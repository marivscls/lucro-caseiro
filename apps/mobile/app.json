{
  "expo": {
    "name": "Lucro Caseiro: Negocio em Casa",
    "slug": "lucro-caseiro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "lucrocaseiro",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#22C55E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lucrocaseiro.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#22C55E"
      },
      "package": "br.com.orionseven.lucrocaseiro"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#22C55E",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar suas fotos para adicionar imagens a produtos e receitas.",
          "cameraPermission": "O app precisa acessar a camera para tirar fotos de produtos e receitas."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8304398247631710~5581735015",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "83a64ebe-a3e6-408a-b0f9-a076445bfa68"
      },
      "revenuecat": {
        "iosKey": "",
        "androidKey": "",
        "entitlementId": "premium"
      },
      "admob": {
        "bannerUnitIdAndroid": "ca-app-pub-8304398247631710/6992108312",
        "interstitialUnitIdAndroid": ""
      }
    }
  }
}
