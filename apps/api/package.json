{
  "name": "@lucro-caseiro/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/main.ts",
    "build": "tsc",
    "start": "node --import tsx src/main.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
