# API
NODE_ENV=development
API_PORT=3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/lucro_caseiro
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Necessaria apenas para exclusao de conta (auth.admin). Segredo, so no backend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CORS_ORIGIN=*
