{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm install --frozen-lockfile --ignore-scripts && node scripts/railway-service.mjs build"
  },
  "deploy": {
    "startCommand": "node scripts/railway-service.mjs start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
