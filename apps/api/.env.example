# Lucro Caseiro API — environment variables
# Copy to .env and fill in values for local dev. For production, set these in your host (Railway/Fly/Render).

# Runtime
NODE_ENV=production
API_PORT=3001

# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# CORS — origins allowed to call the API. Use comma-separated list or "*" for any.
CORS_ORIGIN=*

# RevenueCat webhook
# Generate a long random string and configure the same in RevenueCat dashboard:
# Integrations > Webhooks > Authorization Header: Bearer <this_secret>
REVENUECAT_WEBHOOK_SECRET=

# Mercado Pago (optional — only if you enable PIX/cartao alternative payment)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_PLAN_MONTHLY_ID=
MERCADOPAGO_PLAN_ANNUAL_ID=
