{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @lucro-caseiro/web build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @lucro-caseiro/web start",
    "healthcheckPath": "/login",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
