{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://10.0.2.2:3001"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://lucro-caseiro-production.up.railway.app",
        "EXPO_PUBLIC_AUTH_REDIRECT_URL": "lucrocaseiro://"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://lucro-caseiro-production.up.railway.app",
        "EXPO_PUBLIC_AUTH_REDIRECT_URL": "lucrocaseiro://"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
