# API
NODE_ENV=development
API_PORT=3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/lucro_caseiro
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Necessaria apenas para exclusao de conta (auth.admin). Segredo, so no backend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# UUIDs do Supabase Auth autorizados a abrir o painel interno de métricas.
ADMIN_USER_IDS=
CORS_ORIGIN=*
GOOGLE_PLAY_PACKAGE_NAME=br.com.orionseven.lucrocaseiro
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ESSENTIAL_MONTHLY_ID=
STRIPE_PRICE_ESSENTIAL_ANNUAL_ID=
STRIPE_PRICE_PROFESSIONAL_MONTHLY_ID=
STRIPE_PRICE_PROFESSIONAL_ANNUAL_ID=
STRIPE_SUCCESS_URL=https://lucrocaseiro.app/checkout/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://lucrocaseiro.app/checkout/cancel

# Site público
NEXT_PUBLIC_SITE_URL=https://lucrocaseiro.com.br
# Opcional: ativa Google Analytics no site público.
NEXT_PUBLIC_GA_ID=

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_AUTH_REDIRECT_URL=lucrocaseiro://

# Whitelabel: cada deploy/build define uma marca. O default e lucro-caseiro.
BRAND=lucro-caseiro
NEXT_PUBLIC_BRAND=lucro-caseiro
EXPO_PUBLIC_BRAND=lucro-caseiro
EXPO_PUBLIC_CATALOG_URL=https://catalogo.lucrocaseiro.com.br
EAS_PROJECT_ID=

# AdMob por marca: valores reais vivem no cofre do ambiente/EAS.
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=
EXPO_PUBLIC_ADMOB_IOS_APP_ID=
EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID_ANDROID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_UNIT_ID_ANDROID=
