# Lucro Caseiro API - environment variables
# Copy to .env and fill in values for local dev. For production, set these in your host (Railway/Fly/Render).

# Runtime
NODE_ENV=production
API_PORT=3001

# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
# Service-role key (Dashboard -> Project Settings -> API -> service_role).
# Necessaria APENAS para exclusao de conta (auth.admin.deleteUser). SEGREDO:
# nunca commitar, nunca expor ao mobile. Sem ela, DELETE /api/v1/account -> 503.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# CORS - origins allowed to call the API. Use comma-separated list or "*" for any.
CORS_ORIGIN=*

# Google Play Billing validation
GOOGLE_PLAY_PACKAGE_NAME=br.com.orionseven.lucrocaseiro
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# Stripe Billing / Checkout
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY_ID=
STRIPE_PRICE_ANNUAL_ID=
STRIPE_SUCCESS_URL=https://lucrocaseiro.app/checkout/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://lucrocaseiro.app/checkout/cancel
